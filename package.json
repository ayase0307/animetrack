{
  "name": "animetrack",
  "version": "0.4.0",
  "description": "追劇小幫手桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ayase0307.animetrack",
    "productName": "追劇小幫手",
    "artifactName": "AnimeTrack-Setup-${version}.${ext}",
    "icon": "enso-play-icon.png",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "viewer.html",
      "*.png",
      "*.svg",
      "assets/*.png"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ayase0307",
        "repo": "animetrack"
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
